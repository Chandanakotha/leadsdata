# ─────────────────────────────────────────────
#  Email Marketing Automation Dashboard
#  Environment Variables Reference
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, Railway, etc.)
# Get from: Supabase → Settings → Database → URI
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ── Email Sending ─────────────────────────────
# Resend API key for sending cold emails
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Verified sender address (must be a verified domain in Resend)
# Defaults to noreply@resend.dev (testing only — goes to spam in production)
RESEND_FROM_EMAIL=outreach@yourdomain.com

# ── Authentication ────────────────────────────
# Admin password to log in to the dashboard
# Choose a strong password (20+ characters recommended)
ADMIN_PASSWORD=your-strong-admin-password-here

# Session signing secret — any long random string (32+ characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-random-session-secret-at-least-32-chars

# ── Server ────────────────────────────────────
# Port for the API server (Railway sets this automatically)
PORT=8080

# Node environment: development | production
NODE_ENV=development

# ── CORS (production only) ────────────────────
# Your deployed frontend URL — tells the API which origin to allow
# Set this in Railway after deploying Vercel frontend
FRONTEND_URL=https://your-app.vercel.app
