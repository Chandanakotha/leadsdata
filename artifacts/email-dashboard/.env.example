# ─────────────────────────────────────────────
#  Frontend Environment Variables
#  Copy this file to .env.local for local dev
# ─────────────────────────────────────────────

# API base URL — only needed when the API and frontend are on different domains
# In development (Replit or local), leave this unset — relative /api paths are used
# In production (Vercel), set this to your Railway API URL
VITE_API_BASE_URL=https://your-api.up.railway.app/api
